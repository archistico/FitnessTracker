{% extends 'base.html.twig' %}

{% block title %}{{ plan.name }} · FitnessTracker{% endblock %}
{% block page_title %}{{ plan.name }}{% endblock %}
{% block page_subtitle %}
    <div class="text-secondary">{{ plan.goal.label }} · {{ plan.suggestedDayLabel }} · {{ plan.active ? 'Scheda attiva' : 'Scheda disattivata' }}</div>
{% endblock %}
{% block page_actions %}
    <div class="btn-list">
        <form method="post" action="{{ path('app_workout_session_start_from_plan', { slug: plan.slug }) }}">
            <button class="btn btn-primary" type="submit" {% if plan.exercises|length == 0 %}disabled{% endif %}>
                <span class="ti ti-player-play me-1"></span>
                Avvia allenamento
            </button>
        </form>
        <a href="{{ path('app_workout_plan_edit', { slug: plan.slug }) }}" class="btn btn-outline-primary">
            <span class="ti ti-pencil me-1"></span>
            Modifica scheda
        </a>
        <form method="post" action="{{ path('app_workout_plan_duplicate', { slug: plan.slug }) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('duplicate_workout_plan_' ~ plan.id) }}">
            <button class="btn btn-outline-primary" type="submit">
                <span class="ti ti-copy me-1"></span>
                Duplica
            </button>
        </form>
        <a href="{{ path('app_workout_plan_index') }}" class="btn btn-outline-secondary">Tutte le schede</a>
    </div>
{% endblock %}

{% block body %}
<div class="row row-cards">
    <div class="col-lg-8">
        <div class="app-mobile-card">
            <div class="app-mobile-card-header">
                <div class="d-flex gap-3 align-items-start">
                    <div class="app-card-number"><span class="ti ti-list-check"></span></div>
                    <div>
                        <h3 class="card-title mb-1">Esercizi pianificati</h3>
                        <div class="text-secondary small">Ordine, prescrizione e progressione per ogni esercizio.</div>
                    </div>
                </div>
            </div>
            <div class="app-mobile-card-body">
                {% for item in plan.exercises %}
                    <div class="app-mobile-card {% if not loop.first %}mt-3{% endif %}" id="item-{{ item.id }}">
                        <div class="app-mobile-card-header">
                            <div class="d-flex gap-3 align-items-start">
                                <div class="app-card-number">{{ item.position }}</div>
                                <div>
                                    <h3 class="card-title mb-1">{{ item.exercise.name }}</h3>
                                    <div class="text-secondary small">{{ item.exercise.trackingMode.label }}</div>
                                </div>
                            </div>
                            <span class="badge bg-blue-lt">{{ item.progressionType.label }}</span>
                        </div>
                        <div class="app-mobile-card-body">
                            <div class="app-info-grid">
                                <div class="app-info-item">
                                    <div class="app-info-label">Prescrizione</div>
                                    <div class="app-info-value">{{ item.prescriptionSummary }}</div>
                                </div>
                                <div class="app-info-item">
                                    <div class="app-info-label">Recupero</div>
                                    <div class="app-info-value">{{ item.restSummary }}</div>
                                </div>
                                <div class="app-info-item">
                                    <div class="app-info-label">Progressione</div>
                                    <div class="app-info-value">{{ item.progressionType.label }}</div>
                                </div>
                            </div>
                            {% if item.notes %}
                                <div class="app-section">
                                    <div class="app-section-title">Note</div>
                                    <p class="app-description text-secondary mb-0">{{ item.notes }}</p>
                                </div>
                            {% endif %}

                            <form method="post" action="{{ path('app_workout_plan_edit_exercise', { slug: plan.slug, itemId: item.id }) }}" class="app-section">
                                <div class="app-section-title">Modifica riga esercizio</div>
                                <div class="app-field-grid">
                                    <div>
                                        <label class="form-label" for="progressionType-{{ item.id }}">Progressione</label>
                                        <select class="form-select" id="progressionType-{{ item.id }}" name="progressionType">
                                            {% for progressionType in progressionTypes %}
                                                <option value="{{ progressionType.value }}" {% if item.progressionType == progressionType %}selected{% endif %}>{{ progressionType.label }}</option>
                                            {% endfor %}
                                        </select>
                                        <div class="app-info-help">Le combinazioni non coerenti vengono bloccate prima del salvataggio.</div>
                                    </div>
                                    <div>
                                        <label class="form-label" for="plannedSets-{{ item.id }}">Serie</label>
                                        <input class="form-control" id="plannedSets-{{ item.id }}" name="plannedSets" type="number" min="1" value="{{ item.plannedSets }}" placeholder="3">
                                    </div>
                                    <div>
                                        <label class="form-label" for="plannedRepMin-{{ item.id }}">Rep min</label>
                                        <input class="form-control" id="plannedRepMin-{{ item.id }}" name="plannedRepMin" type="number" min="1" value="{{ item.plannedRepMin }}" placeholder="8">
                                    </div>
                                    <div>
                                        <label class="form-label" for="plannedRepMax-{{ item.id }}">Rep max</label>
                                        <input class="form-control" id="plannedRepMax-{{ item.id }}" name="plannedRepMax" type="number" min="1" value="{{ item.plannedRepMax }}" placeholder="10">
                                    </div>
                                    <div>
                                        <label class="form-label" for="plannedDurationSeconds-{{ item.id }}">Durata sec.</label>
                                        <input class="form-control" id="plannedDurationSeconds-{{ item.id }}" name="plannedDurationSeconds" type="number" min="1" value="{{ item.plannedDurationSeconds }}" placeholder="600">
                                    </div>
                                    <div>
                                        <label class="form-label" for="plannedRestSeconds-{{ item.id }}">Recupero sec.</label>
                                        <input class="form-control" id="plannedRestSeconds-{{ item.id }}" name="plannedRestSeconds" type="number" min="1" value="{{ item.plannedRestSeconds }}" placeholder="150">
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <label class="form-label" for="notes-{{ item.id }}">Note esercizio</label>
                                    <textarea class="form-control app-touch-control" id="notes-{{ item.id }}" name="notes" rows="2">{{ item.notes }}</textarea>
                                </div>
                                <div class="app-action-grid mt-3">
                                    <button class="btn btn-outline-primary" type="submit">Salva riga</button>
                                </div>
                            </form>
                        </div>
                        <div class="app-mobile-card-footer app-action-grid">
                            <form method="post" action="{{ path('app_workout_plan_exercise_move_up', { slug: plan.slug, itemId: item.id }) }}" class="app-mobile-full">
                                <button class="btn btn-outline-secondary w-100" type="submit" {% if loop.first %}disabled{% endif %}>Sposta su</button>
                            </form>
                            <form method="post" action="{{ path('app_workout_plan_exercise_move_down', { slug: plan.slug, itemId: item.id }) }}" class="app-mobile-full">
                                <button class="btn btn-outline-secondary w-100" type="submit" {% if loop.last %}disabled{% endif %}>Sposta giù</button>
                            </form>
                            <form method="post" action="{{ path('app_workout_plan_remove_exercise', { slug: plan.slug, itemId: item.id }) }}" class="app-mobile-full app-danger-action" data-confirm-title="Rimuovi esercizio" data-confirm-message="Rimuovere &quot;{{ item.exercise.name }}&quot; dalla scheda &quot;{{ plan.name }}&quot;?" data-confirm-submit-label="Rimuovi">
                                <button class="btn btn-outline-danger w-100" type="submit">Rimuovi</button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="empty">
                        <p class="empty-title">Nessun esercizio ancora inserito</p>
                        <p class="empty-subtitle text-secondary">Aggiungi il primo esercizio dal pannello laterale.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <form method="post" action="{{ path('app_workout_plan_add_exercise', { slug: plan.slug }) }}" class="app-mobile-card" id="add-exercise">
            <div class="app-mobile-card-header">
                <div class="d-flex gap-3 align-items-start">
                    <div class="app-card-number"><span class="ti ti-plus"></span></div>
                    <div>
                        <h3 class="card-title mb-1">Aggiungi esercizio</h3>
                        <div class="text-secondary small">{{ availableExerciseCount }} disponibili su {{ exercises|length }} esercizi.</div>
                    </div>
                </div>
            </div>
            <div class="app-mobile-card-body">
                <div class="app-section">
                    <div class="app-section-title">Esercizio e progressione</div>
                    <div class="mb-3">
                        <label class="form-label" for="exerciseSearch">Cerca esercizio</label>
                        <input class="form-control app-touch-control" id="exerciseSearch" type="search" placeholder="Scrivi nome, muscolo o attrezzatura..." data-exercise-select-filter="#exerciseId">
                        <div class="app-info-help">Filtra l'elenco sotto senza ricaricare la pagina. Utile con cataloghi grandi.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" id="availableExercisesOnly" data-exercise-available-toggle="#exerciseId" checked>
                            <span class="form-check-label">Mostra solo esercizi disponibili nella mia palestra</span>
                        </label>
                        <div class="app-info-help">Gli esercizi con attrezzatura disattivata restano consultabili togliendo la spunta.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="exerciseId">Esercizio</label>
                        <select class="form-select app-touch-control" id="exerciseId" name="exerciseId" required>
                            <option value="" data-search="" data-available="1">Seleziona esercizio...</option>
                            {% for exercise in exercises %}
                                {% set equipment = exercise.defaultEquipment %}
                                {% set isAvailable = equipment is null or equipment.slug in availableEquipmentSlugs %}
                                {% set availabilityLabel = isAvailable ? 'disponibile' : 'non disponibile' %}
                                {% set searchText = exercise.name ~ ' ' ~ exercise.trackingMode.label ~ ' ' ~ exercise.description ~ ' ' ~ exercise.primaryMuscles|join(' ') ~ ' ' ~ exercise.secondaryMuscles|join(' ') ~ ' ' ~ (equipment ? equipment.name : '') ~ ' ' ~ availabilityLabel %}
                                <option value="{{ exercise.id }}" data-search="{{ searchText|lower }}" data-available="{{ isAvailable ? '1' : '0' }}">
                                    {{ exercise.name }} · {{ exercise.trackingMode.label }}{% if equipment %} · {{ equipment.name }}{% endif %}{% if not isAvailable %} · non disponibile{% endif %}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="progressionType">Progressione</label>
                        <select class="form-select app-touch-control" id="progressionType" name="progressionType">
                            {% for progressionType in progressionTypes %}
                                <option value="{{ progressionType.value }}">{{ progressionType.label }}</option>
                            {% endfor %}
                        </select>
                        <div class="app-info-help">Se scegli Trenino Invictus, l'allenamento genererà automaticamente lo step 1: 2 serie 8-10 e 2 serie 10-12. I carichi arrivano dalla calibrazione, se presente.</div>
                    </div>
                    <div class="alert alert-info mt-3 mb-0">
                        <strong>Regole rapide.</strong>
                        Trenino richiede esercizi Peso + reps. Serie fisse/manuali richiedono serie e Rep min per gli esercizi a ripetizioni. A tempo/Cardio richiedono la durata.
                    </div>
                </div>

                <div class="app-section">
                    <div class="app-section-title">Prescrizione</div>
                    <div class="app-field-grid">
                        <div>
                            <label class="form-label" for="plannedSets">Serie</label>
                            <input class="form-control" id="plannedSets" name="plannedSets" type="number" min="1" placeholder="3">
                        </div>
                        <div>
                            <label class="form-label" for="plannedRepMin">Rep min</label>
                            <input class="form-control" id="plannedRepMin" name="plannedRepMin" type="number" min="1" placeholder="8">
                        </div>
                        <div>
                            <label class="form-label" for="plannedRepMax">Rep max</label>
                            <input class="form-control" id="plannedRepMax" name="plannedRepMax" type="number" min="1" placeholder="10">
                        </div>
                        <div>
                            <label class="form-label" for="plannedDurationSeconds">Durata sec.</label>
                            <input class="form-control" id="plannedDurationSeconds" name="plannedDurationSeconds" type="number" min="1" placeholder="600">
                        </div>
                        <div>
                            <label class="form-label" for="plannedRestSeconds">Recupero sec.</label>
                            <input class="form-control" id="plannedRestSeconds" name="plannedRestSeconds" type="number" min="1" placeholder="150">
                        </div>
                    </div>
                </div>

                <div class="app-section">
                    <div class="app-section-title">Note</div>
                    <label class="form-label" for="notes">Note esercizio</label>
                    <textarea class="form-control app-touch-control" id="notes" name="notes" rows="3" placeholder="Esempio: usare come riscaldamento, non andare a cedimento..."></textarea>
                </div>
            </div>
            <div class="app-mobile-card-footer app-action-grid">
                <button class="btn btn-primary" type="submit">Aggiungi alla scheda</button>
            </div>
        </form>

        <div class="app-mobile-card mt-3">
            <div class="app-mobile-card-header">
                <div class="d-flex gap-3 align-items-start">
                    <div class="app-card-number"><span class="ti ti-trash"></span></div>
                    <div>
                        <h3 class="card-title mb-1">Elimina scheda</h3>
                        <div class="text-secondary small">Azione definitiva sulla scheda.</div>
                    </div>
                </div>
            </div>
            <div class="app-mobile-card-body">
                <p class="app-description text-secondary mb-0">
                    Le sessioni già create restano nello storico, ma perderanno il collegamento alla scheda eliminata.
                </p>
            </div>
            <div class="app-mobile-card-footer app-action-grid">
                <form class="app-danger-action" method="post" action="{{ path('app_workout_plan_delete', { slug: plan.slug }) }}" data-confirm-title="Elimina scheda" data-confirm-message="Eliminare definitivamente la scheda &quot;{{ plan.name }}&quot;? Le sessioni storiche resteranno nel diario senza collegamento alla scheda." data-confirm-submit-label="Elimina">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_workout_plan_' ~ plan.id) }}">
                    <button class="btn btn-outline-danger w-100" type="submit">Elimina scheda</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-exercise-select-filter]').forEach(function (input) {
                const select = document.querySelector(input.dataset.exerciseSelectFilter);
                if (!select) {
                    return;
                }

                const availabilityToggle = document.querySelector('[data-exercise-available-toggle="' + input.dataset.exerciseSelectFilter + '"]');
                const options = Array.from(select.options).map(function (option) {
                    return {
                        element: option,
                        text: (option.dataset.search || option.textContent || '').toLowerCase(),
                        available: option.dataset.available !== '0',
                    };
                });

                const applyFilter = function () {
                    const query = input.value.trim().toLowerCase();
                    const availableOnly = availabilityToggle ? availabilityToggle.checked : false;
                    let firstVisible = null;

                    options.forEach(function (item) {
                        const isPlaceholder = item.element.value === '';
                        const matchesQuery = query === '' || item.text.includes(query);
                        const matchesAvailability = isPlaceholder || !availableOnly || item.available;
                        const visible = matchesQuery && matchesAvailability;

                        item.element.hidden = !visible;
                        item.element.disabled = !visible || isPlaceholder;

                        if (!isPlaceholder && visible && firstVisible === null) {
                            firstVisible = item.element;
                        }
                    });

                    if (select.selectedOptions.length === 0 || select.selectedOptions[0].disabled || select.selectedOptions[0].hidden) {
                        select.value = firstVisible ? firstVisible.value : '';
                    }
                };

                input.addEventListener('input', applyFilter);
                if (availabilityToggle) {
                    availabilityToggle.addEventListener('change', applyFilter);
                }
                applyFilter();
            });
        });
    </script>
{% endblock %}
