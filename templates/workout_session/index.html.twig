{% extends 'base.html.twig' %}

{% block title %}Diario allenamenti · FitnessTracker{% endblock %}
{% block page_title %}Diario allenamenti{% endblock %}
{% block page_subtitle %}
    <div class="text-secondary mt-1">Sessioni reali create dalle schede e registrazione delle serie effettive.</div>
{% endblock %}
{% block page_actions %}
    <a href="{{ path('app_workout_plan_index') }}" class="btn btn-primary">Avvia da una scheda</a>
{% endblock %}

{% block body %}
<div class="row row-cards">
    {% for session in sessions %}
        <div class="col-md-6">
            <div class="app-mobile-card">
                <div class="app-mobile-card-header">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="app-card-number"><span class="ti ti-notebook"></span></div>
                        <div>
                            <h3 class="card-title mb-1">{{ session.sessionDate|date('d/m/Y') }}</h3>
                            <div class="text-secondary small">Avviato {{ session.startedAt|date('H:i') }}</div>
                        </div>
                    </div>
                    <span class="badge {{ session.status.badgeClass }}">{{ session.status.label }}</span>
                </div>
                <div class="app-mobile-card-body">
                    <div class="app-info-grid">
                        <div class="app-info-item">
                            <div class="app-info-label">Scheda</div>
                            <div class="app-info-value">{{ session.workoutPlan ? session.workoutPlan.name : 'Allenamento libero' }}</div>
                        </div>
                        <div class="app-info-item">
                            <div class="app-info-label">Tipo</div>
                            <div class="app-info-value">{{ session.sessionType.label }}</div>
                        </div>
                        <div class="app-info-item">
                            <div class="app-info-label">Serie</div>
                            <div class="app-info-value">{{ session.completedSetCount }}/{{ session.plannedSetCount }}</div>
                        </div>
                    </div>
                </div>
                <div class="app-mobile-card-footer app-action-grid">
                    <a class="btn btn-outline-primary" href="{{ path('app_workout_session_show', { id: session.id }) }}">Apri allenamento</a>
                    <a class="btn btn-outline-secondary" href="{{ path('app_workout_session_edit', { id: session.id }) }}">Modifica</a>
                    <form method="post" action="{{ path('app_workout_session_delete', { id: session.id }) }}" class="app-mobile-full app-danger-action" data-confirm-title="Elimina sessione" data-confirm-message="Eliminare definitivamente la sessione del {{ session.sessionDate|date('d/m/Y') }}{% if session.workoutPlan %} - {{ session.workoutPlan.name }}{% endif %}?" data-confirm-submit-label="Elimina">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_workout_session_' ~ session.id) }}">
                        <button class="btn btn-outline-danger w-100" type="submit">Elimina</button>
                    </form>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="empty">
                <p class="empty-title">Nessun allenamento registrato</p>
                <p class="empty-subtitle text-secondary">Apri una scheda e premi “Avvia allenamento”.</p>
                <div class="empty-action">
                    <a href="{{ path('app_workout_plan_index') }}" class="btn btn-primary">Vai alle schede</a>
                </div>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
