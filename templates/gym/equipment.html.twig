{% extends 'base.html.twig' %}

{% block title %}La mia palestra · FitnessTracker{% endblock %}
{% block page_title %}La mia palestra{% endblock %}
{% block page_subtitle %}
    <div class="text-secondary mt-1">Seleziona quali strumenti sono davvero disponibili. I futuri consigli useranno questa configurazione.</div>
{% endblock %}

{% block body %}
<div class="row row-cards">
    <div class="col-12">
        <div class="app-mobile-card">
            <div class="app-mobile-card-header">
                <div class="d-flex gap-3 align-items-start">
                    <div class="app-card-number"><span class="ti ti-building-gym"></span></div>
                    <div>
                        <h3 class="card-title mb-1">{{ gymProfile.name }}</h3>
                        <div class="text-secondary small">{{ gymProfile.notes ?: 'Configura cosa è presente nella palestra.' }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% for item in items %}
        <div class="col-md-6">
            <div class="app-mobile-card">
                <div class="app-mobile-card-header">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="app-card-number"><span class="ti ti-tools"></span></div>
                        <div>
                            <h3 class="card-title mb-1">
                                <a href="{{ path('app_equipment_show', {slug: item.equipment.slug}) }}">{{ item.equipment.name }}</a>
                            </h3>
                            <div class="text-secondary small">{{ item.equipment.type.value }}</div>
                        </div>
                    </div>
                    {% if item.available %}
                        <span class="badge bg-green-lt">disponibile</span>
                    {% else %}
                        <span class="badge bg-red-lt">non disponibile</span>
                    {% endif %}
                </div>
                <div class="app-mobile-card-body">
                    <p class="app-description text-secondary mb-0">{{ item.equipment.description }}</p>
                </div>
                <div class="app-mobile-card-footer app-action-grid">
                    <form method="post" action="{{ path('app_gym_equipment_toggle', {id: item.id}) }}" class="w-100">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_gym_equipment_' ~ item.id) }}">
                        <button type="submit" class="btn w-100 {{ item.available ? 'btn-outline-danger' : 'btn-outline-success' }}">
                            {{ item.available ? 'Disattiva dalla palestra' : 'Attiva in palestra' }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="empty">
                <p class="empty-title">Nessuna attrezzatura collegata alla palestra</p>
                <p class="empty-subtitle text-secondary">Esegui le fixture per creare la configurazione iniziale.</p>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
